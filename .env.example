# vLLM OpenAI-compatible endpoint
OPENAI_API_KEY=EMPTY
OPENAI_API_BASE=http://127.0.0.1:8000/v1
OPENAI_API_MODEL=mistralai/Voxtral-Mini-4B-Realtime-2602

# Optional endpoint overrides (inherit OPENAI_* when unset)
# STT_API_BASE=http://127.0.0.1:8000/v1
# STT_API_KEY=EMPTY
# TTS_API_BASE=http://127.0.0.1:8000/v1
# TTS_API_KEY=EMPTY

# Realtime service auth (comma-separated)
API_TOKENS=local-dev-token

# Server bind
SERVER_NAME=0.0.0.0
SERVER_PORT=8080

# Optional tuning
REQUEST_TIMEOUT=30
DEFAULT_VAD_AGGR=2
DEFAULT_VAD_START_MS=120
DEFAULT_VAD_END_MS=450
DEFAULT_VAD_PAD_MS=180
DEFAULT_VAD_MAX_MS=5000
DEFAULT_VAD_MIN_VOICE_MS=3000
DEFAULT_VAD_AUTORESP=true
DEFAULT_VAD_INTERRUPT_RESPONSE=false
